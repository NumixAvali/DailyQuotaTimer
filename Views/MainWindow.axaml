<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DailyQuotaTimer.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="250"
        Width="300" Height="250"
        x:Class="DailyQuotaTimer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Daily Quota Timer"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur,Mica">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid
        Margin="15">
        <!-- Actual acrylic blur -->
        <ExperimentalAcrylicBorder
            Margin="-15">
            <!-- That /|\ is such a dumb workaround, I hate it! -->
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial
                    BackgroundSource="Digger"
                    TintColor="{DynamicResource DynamicAcrylicBlurColor}"
                    TintOpacity="0.5"
                    MaterialOpacity="0.25">
                </ExperimentalAcrylicMaterial>
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>
        
        <!-- Top button row -->
        <Grid
            ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
            VerticalAlignment="Top"
            HorizontalAlignment="Center"
        >
            <!-- <Button  -->
            <!--     Grid.Column="5" -->
            <!--     Tag="5" -->
            <!--     Click="TimeButtonUniversal_OnClick">5s -->
            <!-- </Button> -->
            <Button Grid.Column="0" Tag="300" Click="TimeButtonUniversal_OnClick">5m</Button>
            <Button Grid.Column="1" Tag="600" Click="TimeButtonUniversal_OnClick">10m</Button>
            <Button Grid.Column="2" Tag="1800" Click="TimeButtonUniversal_OnClick">30m</Button>
            <Button Grid.Column="3" Tag="3600" Click="TimeButtonUniversal_OnClick">1h</Button>
            <Button Grid.Column="4" Tag="7200" Click="TimeButtonUniversal_OnClick">2h</Button>
        </Grid>
        
        <!-- Central time indicator -->
        <Grid
            ColumnDefinitions="Auto,Auto,Auto,Auto,Auto"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            >
            <TextBlock Grid.Column="0"
                       FontSize="30"
                       x:Name="HourIndicator"
            >00</TextBlock>
            <Label Grid.Column="1"
            FontSize="30"
            >:</Label>
            <TextBlock Grid.Column="2"
                       FontSize="30"
                       x:Name="MinuteIndicator"
            >00</TextBlock>
            <Label Grid.Column="3"
            FontSize="30"
            >:</Label>
            <TextBlock Grid.Column="4"
                       FontSize="30"
                       x:Name="SecondIndicator"
            >00</TextBlock>
        </Grid>
        
        <!-- Set/Add button -->
        <Button
            ToolTip.Tip="Set time mode."
            x:Name="ToggleTimeModeButton"
            Click="ToggleTimeModeButton_OnClick"
            >=</Button>
        
        <!-- Topmost toggle button -->
        <Button
            x:Name="TopmostToggleButton"
            HorizontalAlignment="Right"
            ToolTip.Tip="Toggle above all windows mode."
            Click="ToggleTopmostModeButton_OnClick"
            >⏫</Button>
        
        <!-- Lower control button row -->
        <Grid
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            
            ColumnDefinitions="Auto,Auto,Auto"
            >
            <Button
                Grid.Column="0"
                Click="StartButton_OnClick">
                Start
            </Button>
            <Button
                Grid.Column="1"
                Click="StopButton_OnClick"
                >Stop
            </Button>
            <Button
                Grid.Column="2"
                Click="ResetButton_OnClick"
                >Reset</Button>

        </Grid>
        
        
    </Grid>
    
    

</Window>
